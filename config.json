{
  "input": [
    {
      "type": "text",
      "action": "add",
      "args": {
        "inputDir": "./data/ips",
        "ipVersion": "ipv4"
      }
    }
  ],
  "output": [
    {
      "type": "binary",
      "action": "write",
      "args": {
        "outputFile": "./geoip_tbd.dat",
        "format": "dat"
      }
    }
  ]
}